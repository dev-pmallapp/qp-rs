####################################################################
# Battery fault-injection smoke test вЂ” standalone Renode script.
#
# Loads the LR1121 platform, runs virtual time in three phases:
#   Phase 1 (3 s)  вЂ” normal boot; first TxDone cycle should complete.
#   Phase 2 (6 s)  вЂ” battery fault injected; Fault transitions expected.
#   Phase 3 (8 s)  вЂ” battery restored; recovery cycle expected.
#
# Expected qspy output (connect before running):
#   Phase 1:  BatteryManagerAO Samplingв†’Idle  [HealthReport]
#             CommEndpointAO   Transmittingв†’BoundIdle [TxDone]
#             AppCoordinatorAO Transmittingв†’Idle [TxDone]
#   Phase 2:  BatteryManagerAO Samplingв†’Fault [HealthReport]   в†ђ injected
#             AppCoordinatorAO Idleв†’Fault      [Fault]
#   Phase 3:  AppCoordinatorAO Faultв†’Sampling [SampleRequest]  в†ђ recovery
#             SensorManagerAO  Idleв†’Sampling   [SampleRequest]
#             SensorManagerAO  Samplingв†’Idle   [SampleReady]
#
# Usage (from Renode Monitor):
#   include @configs/renode/tests/integration/battery/fault.resc
#
# For qspy output (start BEFORE include):
#   qspy -t -p 7777
####################################################################

# Load the full LR1121 platform (machine, firmware, peripherals).
include @configs/renode/platform/riscv/esp32c6_lr1121/esp32c6_lr1121.resc

# Expose USB JTAG over TCP for qspy (start qspy -t -p 7777 before running this).
runMacro $setup_qspy

echo ""
echo "в•ђв•ђв•ђ Phase 1: Normal boot (3 virtual seconds) в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
start
emulation RunFor "00:00:03"
pause
echo " вњ“ Phase 1 complete вЂ” check qspy for TxDone transition."

echo ""
echo "в•ђв•ђв•ђ Phase 2: Injecting battery fault (1000 mV) в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
sysbus WriteDoubleWord 0x6000EFF0 1000
echo " Fault voltage set.  Running 6 virtual seconds..."
start
emulation RunFor "00:00:06"
pause
echo " вњ“ Phase 2 complete вЂ” check qspy for BatteryManagerAOв†’Fault."

echo ""
echo "в•ђв•ђв•ђ Phase 3: Restoring battery (3700 mV) в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
sysbus WriteDoubleWord 0x6000EFF0 3700
echo " Healthy voltage restored.  Running 8 virtual seconds..."
start
emulation RunFor "00:00:08"
pause
echo " вњ“ Phase 3 complete вЂ” check qspy for recovery cycle."

echo ""
echo "в•ђв•ђв•ђ Test complete в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
echo " Battery fault injection smoke test finished."
echo " If no _default_abort was hit the firmware survived all phases."
echo "в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
