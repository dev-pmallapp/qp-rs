// test_flash_platform.repl — Minimal isolation platform for the SPI-NOR
// flash stub. No firmware, no SoC peripherals — just the stub mapped at
// a test-only base address.

cpu: CPU.RiscV32 @ sysbus
    cpuType: "rv32imac"
    timeProvider: empty

flash: Python.PythonPeripheral @ sysbus 0x60020000
    size: 0x8000
    initable: true
    filename: "configs/renode/shared/peripherals/flash/flash_stub.py"

ram: Memory.MappedMemory @ sysbus 0x40000000
    size: 0x1000
