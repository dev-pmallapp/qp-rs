####################################################################
# test_flash_platform.resc — SPI-NOR flash stub isolation
#
# Loads only flash_stub.py at base 0x60020000. No firmware, no CPU
# execution — Robot tests drive registers directly via sysbus
# Write/ReadDoubleWord.
####################################################################

python "import System.IO, System; System.IO.Directory.SetCurrentDirectory(System.Environment.GetEnvironmentVariable('PWD'))"

mach create "FlashStubTest"
machine LoadPlatformDescription @configs/renode/tests/peripherals/flash/test_flash_platform.repl
