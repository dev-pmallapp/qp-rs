####################################################################
# test_lora_swm_platform.resc — LR1121Radio model test platform
#
# Minimal three-machine setup for Robot Framework unit tests.
# No firmware is loaded — tests drive SPI registers directly.
#
# Machines:
#   SWM-Gagan-OHT  — LR1121Radio spi2 at position (0, 0, 0)
#   SWM-Pramukh-MC — LR1121Radio spi2 at position (50, 0, 0)
#   SWM-OOR-Node   — LR1121Radio spi2 at position (300, 0, 0) — out-of-range
# Medium: swmMedium (range 200 units)
####################################################################

python "import System.IO, System; System.IO.Directory.SetCurrentDirectory(System.Environment.GetEnvironmentVariable('PWD'))"

i @configs/renode/shared/peripherals/console/usb_serial_jtag.cs
i @configs/renode/shared/peripherals/lora/lora.cs
# Order matters: lr1121_subghz.cs defines the base class that
# lr1121_radio.cs's LR1121SpiRadio alias derives from.
i @configs/renode/shared/peripherals/lora/lr1121_subghz.cs
i @configs/renode/shared/peripherals/lora/lr1121_radio.cs

emulation CreateIEEE802_15_4Medium "swmMedium"
swmMedium SetRangeWirelessFunction 200

# ── Gagan OHT sensor node ──────────────────────────────────────────
mach create "SWM-Gagan-OHT"
machine LoadPlatformDescription @configs/renode/soc/riscv/esp32c6/esp32c6.repl
sysbus Unregister "spi2"
machine LoadPlatformDescriptionFromString "spi2: SPI.LR1121Radio @ sysbus 0x60081000"
connector Connect sysbus.spi2 "swmMedium"
wireless SetPosition sysbus.spi2 0 0 0
logLevel 3 sysbus.spi2

# ── Pramukh MC master controller ──────────────────────────────────
mach create "SWM-Pramukh-MC"
machine LoadPlatformDescription @configs/renode/soc/riscv/esp32c6/esp32c6.repl
sysbus Unregister "spi2"
machine LoadPlatformDescriptionFromString "spi2: SPI.LR1121Radio @ sysbus 0x60081000"
connector Connect sysbus.spi2 "swmMedium"
wireless SetPosition sysbus.spi2 50 0 0
logLevel 3 sysbus.spi2

# ── Out-of-range node (beyond 200-unit limit) ──────────────────────
mach create "SWM-OOR-Node"
machine LoadPlatformDescription @configs/renode/soc/riscv/esp32c6/esp32c6.repl
sysbus Unregister "spi2"
machine LoadPlatformDescriptionFromString "spi2: SPI.LR1121Radio @ sysbus 0x60081000"
connector Connect sysbus.spi2 "swmMedium"
wireless SetPosition sysbus.spi2 300 0 0
logLevel 3 sysbus.spi2
